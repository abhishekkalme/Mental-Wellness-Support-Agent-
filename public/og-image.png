<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0A0D08;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1a1f17;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#E2FF6F;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#E2FF6F;stop-opacity:0" />
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect x="800" y="0" width="400" height="630" fill="url(#glow)"/>
  <rect x="0" y="400" width="500" height="230" fill="url(#glow)"/>
  <text x="80" y="180" font-family="Arial, sans-serif" font-size="72" font-weight="900" fill="#E2FF6F" letter-spacing="-2">MindCare</text>
  <text x="80" y="240" font-family="Arial, sans-serif" font-size="28" fill="rgba(255,255,255,0.5)" letter-spacing="4">WELLNESS PLATFORM</text>
  <text x="80" y="400" font-family="Arial, sans-serif" font-size="36" fill="rgba(255,255,255,0.8)">AI-powered mental health support</text>
  <text x="80" y="460" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.4)">Track mood · Journal · Breathe · Sleep well</text>
  <circle cx="1050" cy="315" r="120" fill="none" stroke="#E2FF6F" stroke-width="2" opacity="0.3"/>
  <circle cx="1050" cy="315" r="90" fill="none" stroke="#E2FF6F" stroke-width="1" opacity="0.2"/>
  <circle cx="1050" cy="315" r="60" fill="#E2FF6F" opacity="0.15"/>
</svg>